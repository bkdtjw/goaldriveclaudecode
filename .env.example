# 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# Anthropic API Key（必需）
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 可选：默认模型
DEFAULT_MODEL=claude-3-5-sonnet-20241022

# 可选：最大迭代次数
MAX_ITERATIONS=50

# 可选：日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# 可选：会话存储目录
SESSION_DIR=~/.goaldriveclaude/sessions

# 可选：工作目录
WORKING_DIRECTORY=.
